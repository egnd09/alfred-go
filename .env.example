# Server Configuration
SERVICE_PORT=5500
LOG_LEVEL=debug

# Database
DB_MONGO_URI=mongodb://localhost:27017/alfred
REDIS_URL=redis://localhost:6379

# GitHub OAuth (required for authentication)
GITHUB_CLIENTID=your-github-client-id
GITHUB_CLIENTSECRET=your-github-client-secret

# AWS Configuration (required for EKS)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-west-2
EKS_CLUSTER_NAME=your-cluster-name

# Kubernetes (optional - uses in-cluster config if not set)
# KUBECONFIG=/path/to/kubeconfig

# Vault (optional)
# VAULT_ADDR=http://vault:8200
# VAULT_TOKEN=your-vault-token

# ArgoCD (optional)
# ARGOCD_ADDR=argocd.example.com
# ARGOCD_USER=admin
# ARGOCD_PASSWORD=password
